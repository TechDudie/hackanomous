{
    "plugins": ["prettier-plugin-svelte"],
    "printWidth": 6767,
    "tabWidth": 4,
    "useTabs": false,
    "singleQuote": false,
    "jsxSingleQuote": false,
    "trailingComma": "all",
    "arrowParens": "always",
    "bracketSpacing": true,
    "overrides": [
        {
            "files": "*.md",
            "options": {
                "proseWrap": "always"
            }
        },
        {
            "files": "*.svelte",
            "options": {
                "parser": "svelte"
            }
        }
    ]
}
